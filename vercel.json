{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/text-case-converter/(.*)",
      "status": 301,
      "headers": { "Location": "/text-case-convert" }
    },
    {
      "src": "/text-case-converter",
      "status": 301,
      "headers": { "Location": "/text-case-convert" }
    },
    {
      "src": "/text-case",
      "status": 301,
      "headers": { "Location": "/text-case-convert" }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
